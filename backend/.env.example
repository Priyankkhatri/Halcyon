# ── AI Provider ───────────────────────────────────────────────
# Groq API Key (primary LLM provider)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API Key (optional — used if cascadeflow verifier needs OpenAI)
OPENAI_API_KEY=

# ── Hindsight — Agent Memory ──────────────────────────────────
# Run Hindsight locally: docker run -it --pull always -p 8888:8888 -p 9999:9999 \
#   -e HINDSIGHT_API_LLM_API_KEY=$GROQ_API_KEY -e HINDSIGHT_API_LLM_PROVIDER=groq \
#   ghcr.io/vectorize-io/hindsight:latest
HINDSIGHT_URL=http://localhost:8888
HINDSIGHT_BANK_ID=halcyon-incidents
HINDSIGHT_ENABLED=true
MEMORY_MATCH_THRESHOLD=0.80

# ── cascadeflow — Model Routing ───────────────────────────────
CASCADEFLOW_ENABLED=true
CASCADEFLOW_MODE=observe
CASCADEFLOW_BUDGET=0.50
DRAFT_MODEL=llama-3.1-8b-instant
VERIFIER_MODEL=llama-3.3-70b-versatile

# ── Server Settings ───────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=True

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./halcyon.db

# ── Upload Settings ───────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=.log,.txt,.out,.err
UPLOADS_DIR=uploads
