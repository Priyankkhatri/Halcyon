# ── AI Provider ───────────────────────────────────────────────
# Groq API Key (primary LLM provider)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API Key (optional — used if cascadeflow verifier needs OpenAI)
OPENAI_API_KEY=

# ── Local Ollama Serving (Self-hosted model) ──────────────────
OLLAMA_ENABLED=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=halcyon-llama3.2-3b

# ── Hindsight — Agent Memory ──────────────────────────────────
# Run Hindsight locally: docker run -it --pull always -p 8888:8888 -p 9999:9999 \
#   -e HINDSIGHT_API_LLM_API_KEY=$GROQ_API_KEY -e HINDSIGHT_API_LLM_PROVIDER=groq \
#   ghcr.io/vectorize-io/hindsight:latest
HINDSIGHT_URL=http://localhost:8888
HINDSIGHT_BANK_ID=halcyon-incidents
HINDSIGHT_ENABLED=true
MEMORY_MATCH_THRESHOLD=0.80

# ── cascadeflow — Model Routing ───────────────────────────────
CASCADEFLOW_ENABLED=true
CASCADEFLOW_MODE=observe
CASCADEFLOW_BUDGET=0.50
# Primary/cheap model for drafting and fast-path formatting
DRAFT_MODEL=qwen/qwen3-32b
# Stronger model for escalated diagnostic reasoning
VERIFIER_MODEL=llama-3.3-70b-versatile
# Approved local/self-hosted model for sensitive/PII data
COMPLIANCE_MODEL=local/llama-3.1-8b

# ── Server Settings ───────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=True

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./halcyon.db

# ── Upload Settings ───────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=.log,.txt,.out,.err
UPLOADS_DIR=uploads

# ── GitHub Integration ────────────────────────────────────────
# Note: GITHUB_TOKEN and GITHUB_REPO are optional fallback defaults for local dev only.
# Workspace credentials are encrypted and stored in the database.
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_LOOKBACK_MINUTES=60
GITHUB_ENCRYPTION_KEY=your_fernet_encryption_key_here
